---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Writings by Lala — a content library for the long haul.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="theme-color" content="#5a4a7a" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600&family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #faf8f4;
        --paper: #fffdf8;
        --ink: #1a1623;
        --ink-soft: #4a4358;
        --ink-faded: #7a7388;
        --accent: #5a4a7a;
        --accent-soft: #8a7aaa;
        --gold: #a07a3a;
        --line: #e4ded2;
        --shadow: 0 1px 2px rgba(30, 20, 40, 0.06), 0 8px 24px rgba(30, 20, 40, 0.05);
        --shadow-hover: 0 2px 4px rgba(30, 20, 40, 0.08), 0 12px 32px rgba(30, 20, 40, 0.09);
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: 'Source Serif 4', Georgia, serif;
        font-size: clamp(16px, 1rem + 0.2vw, 18px);
        line-height: 1.65;
        color: var(--ink);
        background: var(--bg);
        overflow-wrap: break-word;
      }
      a { color: var(--accent); text-decoration: none; text-underline-offset: 3px; }
      a:hover { text-decoration: underline; }
      h1, h2, h3, h4 { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; color: var(--ink); }
      h1 { font-size: clamp(2rem, 1.5rem + 2.5vw, 3.5rem); margin: 0 0 0.5rem; }
      h2 { font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2.25rem); margin: 2.5rem 0 1rem; }
      h3 { font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem); margin: 2rem 0 0.75rem; font-family: 'Inter', sans-serif; font-weight: 600; letter-spacing: 0.01em; }
      p { margin: 0 0 1.2rem; }
      .nav-font { font-family: 'Inter', sans-serif; }
      .hand { font-family: 'Caveat', cursive; }
      .container { max-width: 1100px; margin: 0 auto; padding: 0 clamp(1rem, 3vw, 2rem); }
      .container-narrow { max-width: 680px; margin: 0 auto; padding: 0 clamp(1rem, 3vw, 2rem); }
      button, a { touch-action: manipulation; }
      @media (prefers-reduced-motion: no-preference) {
        .fade-in { animation: fadeIn 0.6s ease both; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
      }
    </style>
  </head>
  <body>
    <header class="site-nav">
      <div class="container nav-row">
        <a href={base} class="brand">
          <span class="hand brand-hand">Writings</span>
          <span class="nav-font brand-sub">by Lala</span>
        </a>
        <nav class="nav-font main-nav">
          <a href={`${base}/`}>Home</a>
          <a href={`${base}/library/`}>Library</a>
          <a href={`${base}/about/`}>About</a>
        </nav>
      </div>
    </header>

    <main class="fade-in">
      <slot />
    </main>

    <footer class="site-footer nav-font">
      <div class="container footer-row">
        <span>© {new Date().getFullYear()} Lala</span>
        <span class="dot">·</span>
        <span>For the glory of God.</span>
      </div>
    </footer>

    <style>
      .site-nav {
        border-bottom: 1px solid var(--line);
        background: var(--paper);
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(8px);
      }
      .nav-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 64px;
        padding-top: env(safe-area-inset-top);
      }
      .brand {
        color: var(--ink);
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        text-decoration: none;
      }
      .brand-hand { font-size: 1.8rem; color: var(--accent); line-height: 1; }
      .brand-sub { font-size: 0.85rem; color: var(--ink-faded); letter-spacing: 0.02em; }
      .main-nav { display: flex; gap: clamp(1rem, 3vw, 2rem); font-size: 0.95rem; }
      .main-nav a { color: var(--ink-soft); padding: 0.5rem 0; min-height: 44px; display: inline-flex; align-items: center; }
      .main-nav a:hover { color: var(--accent); text-decoration: none; }
      @media (max-width: 520px) {
        .brand-sub { display: none; }
      }

      .site-footer {
        border-top: 1px solid var(--line);
        margin-top: 6rem;
        padding: 2rem 0 calc(2rem + env(safe-area-inset-bottom));
        font-size: 0.85rem;
        color: var(--ink-faded);
      }
      .footer-row { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
      .dot { color: var(--ink-faded); }
    </style>
  </body>
</html>
