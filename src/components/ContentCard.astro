---
import { topicBySlug } from '../topics';
export interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  type: string;
  topics: string[];
  image?: string;
  tiltSeed?: number;
}
const { href, title, description, date, type, topics, image, tiltSeed = 0 } = Astro.props;
const tilt = ((tiltSeed * 7) % 7) - 3; // -3deg to +3deg
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const topicObjs = topics.map((t) => topicBySlug(t)).filter(Boolean);
const base = import.meta.env.BASE_URL;
---
<a class="card" href={href} style={`--tilt: ${tilt}deg;`}>
  <div class="paper">
    {image ? (
      <div class="thumb" style={`background-image: url(${image});`} aria-hidden="true"></div>
    ) : (
      <div class="thumb thumb-placeholder" aria-hidden="true">
        <span class="hand-placeholder">{title.slice(0, 1)}</span>
      </div>
    )}
    <div class="card-body">
      <div class="card-meta nav-font">
        <span class="type-pill">{type}</span>
        <span class="date">{dateStr}</span>
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
      {topicObjs.length > 0 && (
        <div class="card-topics nav-font">
          {topicObjs.map((t) => (
            <a href={`${base}/topics/${t!.slug}/`} class="topic-tag" onclick="event.stopPropagation()">
              {t!.name}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    transform: rotate(var(--tilt));
    transition: transform 0.25s ease, filter 0.25s ease;
  }
  .card:hover, .card:focus-visible {
    transform: rotate(0deg) translateY(-2px);
    filter: drop-shadow(0 8px 20px rgba(60, 40, 90, 0.12));
  }
  .paper {
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    padding: 1rem 1rem 1.25rem;
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }
  .paper::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, rgba(90, 74, 122, 0.15), transparent);
  }
  .thumb {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    background-color: #efe9dd;
    margin-bottom: 1rem;
    border-radius: 1px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.04);
  }
  .thumb-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(
      180deg,
      #f4ede0 0,
      #f4ede0 26px,
      #e8dfd0 26px,
      #e8dfd0 27px
    );
  }
  .hand-placeholder {
    font-family: 'Caveat', cursive;
    font-size: clamp(3rem, 5vw, 5rem);
    color: rgba(90, 74, 122, 0.55);
    transform: rotate(-4deg);
    line-height: 1;
  }
  .card-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.8rem;
    color: var(--ink-faded);
    margin-bottom: 0.5rem;
  }
  .type-pill {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.7rem;
    color: var(--accent);
    font-weight: 600;
  }
  .card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.25rem, 1rem + 0.7vw, 1.6rem);
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--ink);
  }
  .card-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin: 0 0 0.85rem;
    line-height: 1.55;
  }
  .card-topics { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .topic-tag {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    background: rgba(90, 74, 122, 0.07);
    color: var(--accent);
    border-radius: 999px;
    text-decoration: none;
    min-height: 28px;
    display: inline-flex;
    align-items: center;
  }
  .topic-tag:hover { background: rgba(90, 74, 122, 0.14); text-decoration: none; }
</style>
