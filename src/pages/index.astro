---
import Base from '../layouts/Base.astro';
import ContentCard from '../components/ContentCard.astro';
import { getAllEntries, entryUrl } from '../lib/content';
import { TOPICS, TYPES } from '../topics';

const entries = await getAllEntries();
const featured = entries.find((e) => e.data.featured);
const latest = entries.filter((e) => e !== featured).slice(0, 6);
const base = import.meta.env.BASE_URL;

const topicCounts = new Map<string, number>();
for (const e of entries) {
  for (const t of e.data.topics) {
    topicCounts.set(t, (topicCounts.get(t) ?? 0) + 1);
  }
}
---
<Base title="Writings — Shela Heramis">
  <section class="hero container-narrow">
    <p class="hand kicker">writings</p>
    <h1>Notes from a life in progress.</h1>
    <p class="subtitle">
      Content manager. Community builder. Learner. A home for guides, stories,
      field notes, and quiet reflections — built to grow for decades.
    </p>
  </section>

  {featured && (
    <section class="container">
      <h2 class="section-heading">Featured</h2>
      <div class="featured-grid">
        <ContentCard
          href={entryUrl(featured, base)}
          title={featured.data.title}
          description={featured.data.description}
          date={featured.data.date}
          type={featured.data.type}
          topics={featured.data.topics}
          image={featured.data.image}
          tiltSeed={0}
        />
      </div>
    </section>
  )}

  <section class="container">
    <div class="section-head-row">
      <h2 class="section-heading">Latest</h2>
      <a href={`${base}/library/`} class="nav-font see-all">See all →</a>
    </div>
    <div class="card-grid">
      {latest.map((entry, i) => (
        <ContentCard
          href={entryUrl(entry, base)}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          type={entry.data.type}
          topics={entry.data.topics}
          image={entry.data.image}
          tiltSeed={i + 1}
        />
      ))}
      {latest.length === 0 && (
        <p class="empty">The first entry is on its way.</p>
      )}
    </div>
  </section>

  <section class="container">
    <h2 class="section-heading">Browse by topic</h2>
    <div class="topic-grid nav-font">
      {TOPICS.filter((t) => (topicCounts.get(t.slug) ?? 0) > 0).map((t) => (
        <a href={`${base}/topics/${t.slug}/`} class="topic-card">
          <span class="topic-name">{t.name}</span>
          <span class="topic-count">{topicCounts.get(t.slug)}</span>
        </a>
      ))}
      {topicCounts.size === 0 && (
        <p class="empty">Topics populate as entries are published.</p>
      )}
    </div>
  </section>

  <section class="container">
    <h2 class="section-heading">Browse by type</h2>
    <div class="type-row nav-font">
      {TYPES.map((t) => (
        <a href={`${base}/library/?type=${t.slug}`} class="type-chip">{t.label}</a>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero { text-align: center; padding: clamp(3rem, 8vh, 6rem) 0 2rem; }
  .kicker { font-size: 1.5rem; color: var(--accent-soft); margin: 0; }
  .subtitle { color: var(--ink-soft); font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem); margin-top: 1rem; }
  .section-heading { font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem); margin: 3rem 0 1.5rem; }
  .section-head-row { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
  .see-all { color: var(--accent); font-size: 0.9rem; }
  .card-grid, .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.25rem);
    padding: 1rem 0 2rem;
  }
  .featured-grid { grid-template-columns: minmax(280px, 640px); justify-content: center; }
  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .topic-card {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.8rem 1rem; min-height: 48px;
    background: var(--paper); border: 1px solid var(--line); border-radius: 4px;
    color: var(--ink); text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .topic-card:hover { border-color: var(--accent-soft); transform: translateY(-1px); text-decoration: none; }
  .topic-name { font-weight: 500; }
  .topic-count { color: var(--ink-faded); font-size: 0.85rem; }
  .type-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .type-chip {
    padding: 0.55rem 1rem; min-height: 44px; display: inline-flex; align-items: center;
    background: var(--paper); border: 1px solid var(--line); border-radius: 999px;
    color: var(--ink-soft); text-decoration: none; font-size: 0.9rem;
  }
  .type-chip:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
  .empty { color: var(--ink-faded); font-style: italic; }
</style>
