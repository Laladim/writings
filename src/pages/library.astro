---
import Base from '../layouts/Base.astro';
import ContentCard from '../components/ContentCard.astro';
import { getAllEntries, entryUrl } from '../lib/content';
import { TOPICS, TYPES } from '../topics';

const entries = await getAllEntries();
const base = import.meta.env.BASE_URL;
---
<Base title="Library — Writings" description="Every entry, filterable by type and topic.">
  <section class="library-head">
    <p class="hand kicker">library</p>
    <h1>Every entry, filterable.</h1>
    <p class="subtitle">The more gets written, the richer the web.</p>
  </section>

  <section class="filters-section">
    <div class="filters nav-font">
      <div class="filter-group">
        <span class="filter-label">Type</span>
        <div class="chip-row">
          <button class="chip active" data-filter-type="all">All</button>
          {TYPES.map((t) => (
            <button class="chip" data-filter-type={t.slug}>{t.label}</button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">Topic</span>
        <div class="chip-row">
          <button class="chip active" data-filter-topic="all">All</button>
          {TOPICS.map((t) => (
            <button class="chip" data-filter-topic={t.slug}>{t.name}</button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="gallery-wrap">
    <div id="library-grid" class="gallery">
      {entries.map((entry) => (
        <ContentCard
          href={entryUrl(entry, base)}
          title={entry.data.title}
          date={entry.data.date}
          type={entry.data.type}
          topics={entry.data.topics}
          image={entry.data.image}
        />
      ))}
    </div>
    <p id="empty-msg" class="empty" hidden>Nothing matches that filter yet.</p>
    {entries.length === 0 && <p class="empty">The library is empty — the first entry is on its way.</p>}
  </section>
</Base>

<script>
  const grid = document.getElementById('library-grid');
  if (grid) {
    const cards = Array.from(grid.children) as HTMLElement[];
    const cardData = cards.map((el) => ({
      el,
      type: (el.dataset.type ?? '').toLowerCase(),
      topics: (el.dataset.topics ?? '').split(',').filter(Boolean),
    }));

    let activeType = 'all';
    let activeTopic = 'all';

    const apply = () => {
      let shown = 0;
      cardData.forEach((c) => {
        const typeOk = activeType === 'all' || c.type === activeType;
        const topicOk = activeTopic === 'all' || c.topics.includes(activeTopic);
        const show = typeOk && topicOk;
        c.el.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      const empty = document.getElementById('empty-msg');
      if (empty) empty.hidden = shown > 0;
    };

    document.querySelectorAll('[data-filter-type]').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-filter-type]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeType = (btn as HTMLElement).dataset.filterType ?? 'all';
        apply();
      });
    });
    document.querySelectorAll('[data-filter-topic]').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-filter-topic]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeTopic = (btn as HTMLElement).dataset.filterTopic ?? 'all';
        apply();
      });
    });

    const params = new URLSearchParams(window.location.search);
    const t = params.get('type');
    const tp = params.get('topic');
    if (t) {
      const btn = document.querySelector(`[data-filter-type="${t}"]`);
      if (btn) (btn as HTMLElement).click();
    }
    if (tp) {
      const btn = document.querySelector(`[data-filter-topic="${tp}"]`);
      if (btn) (btn as HTMLElement).click();
    }
  }
</script>

<style>
  .library-head {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: clamp(3rem, 8vh, 5rem) clamp(1rem, 3vw, 2rem) 1.5rem;
  }
  .kicker { font-size: 1.3rem; color: var(--accent-soft); margin: 0; }
  .subtitle { color: var(--ink-soft); }

  .filters-section { max-width: 1100px; margin: 0 auto; padding: 1.5rem clamp(1rem, 3vw, 2rem) 1rem; }
  .filters { display: flex; flex-direction: column; gap: 1.25rem; }
  .filter-group { display: flex; gap: 1rem; align-items: flex-start; flex-wrap: wrap; }
  .filter-label {
    color: var(--ink-faded);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding-top: 0.55rem;
    min-width: 50px;
  }
  .chip-row { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .chip {
    padding: 0.45rem 0.85rem;
    min-height: 36px;
    background: transparent;
    border: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    transition: all 0.15s;
  }
  .chip:hover { border-color: var(--accent-soft); color: var(--accent); }
  .chip.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  .gallery-wrap { padding: clamp(2rem, 5vh, 4rem) clamp(1rem, 3vw, 2rem) clamp(3rem, 8vh, 6rem); }
  .gallery {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(3rem, 7vh, 5.5rem) clamp(1rem, 2vw, 2rem);
  }
  .gallery > :nth-child(6n+1) { grid-column: 3 / span 5; }
  .gallery > :nth-child(6n+2) { grid-column: 8 / span 5; }
  .gallery > :nth-child(6n+3) { grid-column: 1 / span 4; }
  .gallery > :nth-child(6n+4) { grid-column: 5 / span 6; }
  .gallery > :nth-child(6n+5) { grid-column: 4 / span 6; }
  .gallery > :nth-child(6n+0) { grid-column: 2 / span 5; }
  @media (max-width: 820px) {
    .gallery { gap: 3.5rem 1rem; }
    .gallery > * { grid-column: 1 / -1 !important; }
  }

  .empty { color: var(--ink-faded); font-style: italic; text-align: center; padding: 2rem 0; }
</style>
